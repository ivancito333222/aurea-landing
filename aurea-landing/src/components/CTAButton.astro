---
interface Props {
  link: string;
  text: string;
  isFloating?: boolean;
  trackingId?: string; // Usaremos esto para parametrizar el clic
}

const { link, text, isFloating = false, trackingId = 'WhatsApp_Lead' } = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-bold text-center transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-xl uppercase tracking-wider select-none focus:outline-none focus:ring-4 focus:ring-emerald-500/30";
const floatingStyles = "fixed bottom-6 right-6 z-50 bg-[#25D366] hover:bg-[#20ba59] text-white px-6 py-4 rounded-full text-sm md:text-base animate-bounce shadow-2xl";
const inlineStyles = "bg-gradient-to-r from-emerald-500 to-green-600 hover:from-emerald-400 hover:to-green-500 text-slate-950 font-black px-8 py-4 rounded-xl text-lg w-full sm:w-auto";
---

<a 
  href={link} 
  target="_blank" 
  rel="noopener noreferrer" 
  class={`${baseStyles} ${isFloating ? floatingStyles : inlineStyles}`}
  aria-label={`Contactar por WhatsApp para: ${text}`}
  onclick={`if(window.ttq) { window.ttq.track('ClickButton', { content_name: '${trackingId}' }); }`}
>
  <svg class="w-6 h-6 mr-3 fill-current" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.4.01 12.008.01c3.202.001 6.212 1.246 8.477 3.517 2.266 2.27 3.51 5.28 3.505 8.484-.017 6.657-5.357 11.993-11.968 11.993-2.015-.001-4.004-.505-5.77-1.467L0 24zm6.208-3.791..."/>
  </svg>
  {text}
</a>