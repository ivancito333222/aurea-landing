---
interface Props {
  link: string;
  text: string;
  isFloating?: boolean;
  trackingId?: string; 
}

const { link, text, isFloating = false, trackingId = 'WhatsApp_Lead' } = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-bold text-center transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-xl uppercase tracking-wider select-none focus:outline-none focus:ring-4 focus:ring-emerald-500/30";
const floatingStyles = "fixed bottom-6 right-6 z-50 bg-[#25D366] hover:bg-[#20ba59] text-white px-6 py-4 rounded-full text-sm md:text-base animate-bounce shadow-2xl";
const inlineStyles = "bg-gradient-to-r from-emerald-500 to-green-600 hover:from-emerald-400 hover:to-green-500 text-slate-950 font-black px-8 py-4 rounded-xl text-lg w-full sm:w-auto";
---

<a 
  href={link} 
  target="_blank" 
  rel="noopener noreferrer" 
  class={`${baseStyles} ${isFloating ? floatingStyles : inlineStyles}`}
  aria-label={`Contactar por WhatsApp para: ${text}`}
  onclick="if(window.ttq) { window.ttq.track('Contact'); }"
>
  <svg class="w-6 h-6 mr-3 fill-current" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.4.01 12.008.01c3.202.001 6.212 1.246 8.477 3.517 2.266 2.27 3.51 5.28 3.505 8.484-.017 6.657-5.357 11.993-11.968 11.993-2.015-.001-4.004-.505-5.77-1.467L0 24zm6.208-3.791c1.678.995 3.334 1.523 5.765 1.525 5.459-.001 9.898-4.437 9.898-9.896.003-2.628-1.02-5.1-2.88-6.963C17.13 3.012 14.655 1.99 12.013 1.99c-5.462 0-9.902 4.437-9.902 9.897-.002 2.142.569 4.23 1.651 6.096l-.997 3.647 3.743-.981zM17.15 14.92c-.283-.141-1.676-.827-1.936-.921-.26-.094-.45-.141-.64.141-.19.283-.736.921-.903 1.11-.166.19-.332.212-.615.071-.283-.141-1.196-.441-2.278-1.408-.841-.75-1.41-1.676-1.575-1.959-.166-.283-.018-.435.123-.574.127-.127.283-.33.424-.495.142-.165.19-.283.283-.472.094-.19.047-.354-.024-.495-.071-.141-.64-1.54-.877-2.11-.231-.557-.466-.482-.64-.491-.166-.008-.356-.01-.545-.01-.19 0-.501.071-.762.354-.26.283-1 .976-1 2.38 0 1.405 1.022 2.761 1.164 2.95 1.408 1.848 1.442 2.827 3.23 3.517.425.164.846.263 1.144.359.534.17 1.02.146 1.404.089.429-.064 1.314-.537 1.498-1.054.184-.518.184-.962.129-1.054-.054-.093-.203-.141-.485-.282z"/>
  </svg>
  {text}
</a>