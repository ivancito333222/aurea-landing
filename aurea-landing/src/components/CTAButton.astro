---
// src/components/CTAButton.astro
import copy from '../data/copy.json';

interface Props {
  link: string;
  text: string;
  isFloating?: boolean;
}

const { link, text, isFloating = false } = Astro.props;
const testCode = copy.settings.metaTestEventCode || '';
const pixelId = copy.settings.metaPixelId || '';

const baseStyles = "inline-flex items-center justify-center font-bold text-center transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-xl uppercase tracking-wider select-none focus:outline-none";
const floatingStyles = "fixed bottom-6 right-6 z-50 bg-[#25D366] hover:bg-[#20ba59] text-white px-6 py-4 rounded-full text-sm shadow-2xl animate-bounce";
const inlineStyles = "bg-gradient-to-r from-emerald-500 to-green-600 hover:from-emerald-400 hover:to-green-500 text-slate-950 px-8 py-4 rounded-xl text-lg w-full sm:w-auto";
---

<a 
  href={link} 
  target="_blank" 
  rel="noopener noreferrer"[cite: 3]
  class={`${baseStyles} ${isFloating ? floatingStyles : inlineStyles}`}
  aria-label={`Contactar por WhatsApp: ${text}`}
  onclick={`
    if(typeof fbq === 'function') {
      const tCode = "${testCode}";
      const pId = "${pixelId}";
      if(tCode && pId) {
        fbq('trackSingle', pId, 'Lead', {}, { test_event_code: tCode });
      } else {
        fbq('track', 'Lead');
      }
    }
  `}
>
  <span class="mr-3">💬</span>
  {text}
</a>