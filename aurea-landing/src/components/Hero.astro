---
// src/components/Hero.astro
const { data } = Astro.props;
---

<section class="relative w-full min-h-[100svh] flex flex-col items-center justify-center bg-aurea-dark px-4 sm:px-6 pt-20 md:pt-28 pb-12 text-center overflow-hidden">
  
  <!-- 1. FONDOS VISUALES Y ORBES DE LUZ (Esperan 3.5s para aparecer) -->
  <div class="absolute inset-0 z-0 hero-visuals">
    <!-- Malla de fondo sutil -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(to right, #ffffff 1px, transparent 1px), linear-gradient(to bottom, #ffffff 1px, transparent 1px); background-size: 40px 40px;"></div>
    
    <!-- Orbe Dorado (Marca Aurea) -->
    <div class="absolute top-1/4 left-0 md:left-1/4 w-64 md:w-96 h-64 md:h-96 bg-gold/20 rounded-full mix-blend-screen filter blur-[100px] animate-pulse-slow"></div>
    
    <!-- Orbe Verde (Conversión WhatsApp) -->
    <div class="absolute bottom-1/4 right-0 md:right-1/4 w-64 md:w-96 h-64 md:h-96 bg-conversion-whatsapp/10 rounded-full mix-blend-screen filter blur-[100px] animate-pulse-slow" style="animation-delay: 2s;"></div>
  </div>

  <!-- 2. INSIGNIAS FLOTANTES GLASSMORPHISM (Solo visibles en PC para no estorbar en móvil) -->
  <div class="hidden lg:flex absolute top-[30%] left-[10%] z-20 badge-float-1">
    <div class="px-5 py-3 rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.3)] flex items-center gap-3">
      <span class="relative flex h-3 w-3">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-conversion-whatsapp opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-conversion-whatsapp"></span>
      </span>
      <span class="text-sm font-bold text-gray-200 tracking-wide">Guardia 24/7 Activo</span>
    </div>
  </div>

  <div class="hidden lg:flex absolute bottom-[35%] right-[10%] z-20 badge-float-2">
    <div class="px-5 py-3 rounded-2xl bg-white/5 backdrop-blur-md border border-gold/30 shadow-[0_8px_32px_rgba(255,215,0,0.1)] flex items-center gap-3">
      <span class="text-xl">⚡</span>
      <span class="text-sm font-bold text-gold-light tracking-wide">Leads Pre-Cualificados</span>
    </div>
  </div>

  <!-- 3. CONTENIDO PRINCIPAL DE VENTAS -->
  <div class="max-w-4xl mx-auto z-10 hero-content flex flex-col items-center w-full relative">
    
    <h1 
      class="text-[2.75rem] md:text-5xl lg:text-7xl font-heading font-extrabold text-content-main mb-6 md:mb-8 leading-[1.1] md:leading-tight tracking-tight w-full drop-shadow-2xl"
      set:html={data.title}
    />
    
    <p class="text-lg md:text-2xl text-content-muted mb-10 md:mb-12 max-w-3xl mx-auto leading-relaxed px-2 font-light">
      {data.subtitle}
    </p>

    <!-- Llamado a la Acción -->
    <a 
      href={data.whatsappLink} 
      target="_blank" 
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center px-8 md:px-12 py-4 md:py-5 text-lg md:text-xl font-bold text-aurea-dark bg-conversion-whatsapp hover:bg-white hover:text-aurea-dark rounded-full transition-all duration-300 transform hover:-translate-y-1 shadow-[0_10px_30px_rgba(37,211,102,0.3)] w-[90%] sm:w-auto border border-transparent hover:border-conversion-whatsapp group"
    >
      <span class="mr-2 group-hover:scale-110 transition-transform">💬</span> 
      {data.ctaText}
    </a>
  </div>
</section>

<style>
  /* Animación de aparición de los textos (3.5s) */
  .hero-content {
    opacity: 0;
    transform: translateY(30px);
    animation: revealHero 1s cubic-bezier(0.4, 0, 0.2, 1) 3.5s forwards;
  }

  /* Animación de aparición de los fondos de luz */
  .hero-visuals {
    opacity: 0;
    animation: fadeIn 2s ease-in-out 3.5s forwards;
  }

  /* Aparición y flotación de la Insignia Izquierda */
  .badge-float-1 {
    opacity: 0;
    transform: translateY(20px);
    animation: 
      revealHero 1s cubic-bezier(0.4, 0, 0.2, 1) 4s forwards,
      floatUpDown 6s ease-in-out 5s infinite;
  }

  /* Aparición y flotación de la Insignia Derecha (Tiempos asimétricos para que luzca natural) */
  .badge-float-2 {
    opacity: 0;
    transform: translateY(20px);
    animation: 
      revealHero 1s cubic-bezier(0.4, 0, 0.2, 1) 4.2s forwards,
      floatUpDown 7s ease-in-out 5.2s infinite alternate;
  }

  @keyframes revealHero {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  /* Efecto de levitación continua para las insignias */
  @keyframes floatUpDown {
    0% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0); }
  }

  /* Respiro sutil para las luces de fondo */
  .animate-pulse-slow {
    animation: pulseSlow 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulseSlow {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>