---
// src/components/Header.astro
const { slogan } = Astro.props;
---

<header class="fixed top-0 left-0 w-full h-20 md:h-24 z-50 flex items-center px-4 md:px-12 pointer-events-none">
  
  <div class="absolute inset-0 bg-aurea-dark/95 backdrop-blur-md border-b border-gold-dark/20 header-bg-reveal"></div>

  <div class="relative w-full flex justify-end items-center z-50">
    <p class="hidden md:block text-gold-light font-heading text-sm tracking-[0.2em] uppercase slogan-reveal font-semibold">
      {slogan}
    </p>
  </div>
</header>

<div class="logo-splash pointer-events-auto flex items-center gap-2 md:gap-3">
  <svg 
    viewBox="0 0 200 200" 
    class="w-20 md:w-28 h-auto drop-shadow-[0_0_15px_rgba(255,215,0,0.4)]"
    xmlns="http://www.w3.org/2000/svg"
  >
    <polygon points="100,10 178,55 178,145 100,190 22,145 22,55" fill="none" stroke="#FFD700" stroke-width="8" class="hex-line" />
    <text x="100" y="118" text-anchor="middle" fill="#FFD700" font-family="monospace" font-size="48" font-weight="bold" class="code-fade">&lt;/&gt;</text>
  </svg>
  <h2 class="text-[1.7rem] md:text-4xl font-heading font-extrabold text-gold tracking-wide logo-text-reveal whitespace-nowrap">
    Aurea Digital Studio
  </h2>
</div>

<style>
  /* 1. ESTADO INICIAL (MÓVIL POR DEFECTO) */
  .logo-splash {
    position: fixed;
    top: 50%;
    left: 50%;
    /* LA MAGIA: Obliga al navegador a no recortar el logo nunca */
    width: max-content; 
    /* Nace un poco más pequeño en móviles (75% de su tamaño) para caber en la pantalla */
    transform: translate(-50%, -50%) scale(0.75); 
    transform-origin: center;
    z-index: 60;
    animation: moveUpMobile 1.2s cubic-bezier(0.8, 0, 0.2, 1) 2.5s forwards;
  }

  /* 📱 TRAYECTORIA MÓVIL: Vuelo recto hacia el centro superior y se encoge más */
  @keyframes moveUpMobile {
    to {
      top: 2.5rem; 
      left: 50%;
      transform: translate(-50%, -50%) scale(0.40); 
    }
  }

  /* 💻 ESTADO INICIAL Y TRAYECTORIA PARA ESCRITORIO (PC/Tablets) */
  @media (min-width: 768px) {
    .logo-splash {
      /* En pantallas grandes sí puede nacer gigante (120% de su tamaño) */
      transform: translate(-50%, -50%) scale(1.2); 
      animation: moveToCornerDesktop 1.2s cubic-bezier(0.8, 0, 0.2, 1) 2.5s forwards;
    }
    
    @keyframes moveToCornerDesktop {
      to {
        top: 3rem;
        /* Viaja a la esquina izquierda de forma matemática y limpia */
        left: 1.5rem;
        transform: translate(0, -50%) scale(0.65);
      }
    }
  }

  /* --- El resto de tus animaciones de dibujado (Intactas) --- */
  .hex-line {
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: drawHexagon 1.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes drawHexagon { to { stroke-dashoffset: 0; } }

  .code-fade {
    opacity: 0;
    animation: fadeIn 0.5s ease-out 1s forwards;
  }

  .logo-text-reveal {
    opacity: 0;
    transform: translateX(-20px);
    animation: revealName 0.5s cubic-bezier(0.4, 0, 0.2, 1) 1.5s forwards;
  }
  @keyframes revealName { to { opacity: 1; transform: translateX(0); } }

  .header-bg-reveal {
    opacity: 0;
    animation: fadeIn 0.5s ease-out 3s forwards;
  }

  .slogan-reveal {
    opacity: 0;
    transform: translateY(10px);
    animation: revealSlogan 0.5s cubic-bezier(0.4, 0, 0.2, 1) 3.2s forwards;
  }
  @keyframes revealSlogan { to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { to { opacity: 1; } }
</style>